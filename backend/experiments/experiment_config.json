{
  "seed": 42,
  "cache_dir": ".cache/hf_datasets",
  "dataset_limit_per_source": 1000,
  "models": {
    "bert": true,
    "gpt": false,
    "llama": false
  },
  "finetuning": {
    "enabled": false,
    "output_dir": "artifacts/finetuned",
    "skip_if_exists": true,
    "epochs": 2,
    "learning_rate": 2e-5,
    "weight_decay": 0.01,
    "train_batch_size": 4,
    "eval_batch_size": 8,
    "dataloader_num_workers": null,
    "fp16": null,
    "bf16": false,
    "gradient_accumulation_steps": 1
  },
  "levels": ["text", "sentence", "token"],
  "text_strategy": "mean",
  "batch_size": 8,
  "max_length": 256,
  "runtime": {
    "cpu_threads": 0,
    "torch_interop_threads": null,
    "tokenizers_parallelism": false,
    "probing_n_jobs": -1
  },
  "runtime_overrides": {
    "bert": {
      "batch_size": 8,
      "max_length": 256
    },
    "gpt": {
      "batch_size": 4,
      "max_length": 192
    },
    "llama": {
      "batch_size": 2,
      "max_length": 128
    }
  },
  "decomposition": {
    "pca_components": 8,
    "enabled_methods": ["pca", "probe_directions", "null_space"],
    "interventions": ["pca", "probe_directions", "null_space"],
    "drop_components": 1
  },
  "tracks": {
    "semantic": {
      "enabled": true,
      "tasks": ["semantic_similarity", "paraphrase"]
    },
    "tone": {
      "enabled": true,
      "tasks": ["sentiment"]
    },
    "style": {
      "enabled": true,
      "tasks": ["emotion"]
    }
  }
}
